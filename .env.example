# Supabase Configuration
# Copy this file to .env.local and fill in your Supabase project details

# Your Supabase project URL (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co

# Your Supabase anon/public key (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_15Ym-9r9crao3f5I9XfbnA_c9KSY273

# Application URL (for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
